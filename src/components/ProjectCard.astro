---
interface Props {
  index: string;
  title: string;
  description: string;
  stack: string[];
  github?: string;
  live?: string;
  year?: string;
}
const { index, title, description, stack, github, live, year = "2024" } = Astro.props;
---

<div class="project-row">
  <div class="pr-index">{index}</div>
  
  <div class="pr-body">
    <div class="pr-header">
      <span class="pr-title">{title}</span>
      <span class="pr-stack">{stack.join(" · ")}</span>
    </div>
    <p class="pr-desc">{description}</p>
  </div>
  
  <div class="pr-right">
    <span class="pr-year">{year}</span>
    <div class="pr-actions">
      {github && (
        <a href={github} class="pr-icon-link" target="_blank" rel="noopener" title="GitHub">
          <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
              0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
              -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
              .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
              -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.65 7.65 0 0 1 2-.27
              c.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
              .51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48
              0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        </a>
      )}
      {live && (
        <a href={live} class="pr-icon-link" target="_blank" rel="noopener" title="Live site">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="2" y1="12" x2="22" y2="12"></line>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
          </svg>
        </a>
      )}
    </div>
  </div>
</div>

<style>
  .project-row {
    display: grid;
    grid-template-columns: 32px 1fr auto;
    gap: 0 20px;
    align-items: start;
    padding: 18px 8px;
    border-bottom: 1px solid var(--border);
    color: var(--blue);
    min-height: 112px;
    margin: 0 -8px;
    transition: background 0.12s;
  }

  .project-row:hover {
    background: var(--blue-subtle);
  }

  .pr-index {
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--blue-dim);
    padding-top: 2px;
    font-variant-numeric: tabular-nums;
  }

  .pr-body {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .pr-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
  }

  .pr-title {
    font-family: var(--font-doto);
    font-variation-settings: "ROND" 0;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue);
  }

  .pr-stack {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue-dim);
  }

  .pr-desc {
    font-size: 13px;
    line-height: 1.6;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--blue-mid);
    max-width: 560px;
  }

  .pr-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    padding-top: 2px;
    flex-shrink: 0;
  }

  .pr-year {
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--blue-dim);
    font-variant-numeric: tabular-nums;
  }

  .pr-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
    margin-top: 6px;
  }

  .pr-icon-link {
    display: flex;
    align-items: center;
    color: var(--blue-dim);
    transition: color 0.15s, transform 0.15s;
  }

  .pr-icon-link svg {
    width: 15px;
    height: 15px;
  }

  .pr-icon-link:hover {
    color: var(--blue);
    transform: translateY(-1px);
  }
</style>
