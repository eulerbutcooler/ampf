---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Hero from "../components/Hero.astro";
import AboutGrid from "../components/AboutGrid.astro";
import RecentBlogs from "../components/RecentBlogs.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import Footer from "../components/Footer.astro";
---

<Layout
    title="eulerbutcooler"
    description="Backend developer building fast, scalable systems, APIs, and infrastructure."
    ogImage={new URL("/og-preview.jpg?v=3", Astro.site).toString()}
>
    <div id="site-wrap">
        <NavBar />
        <Hero />
        <AboutGrid />
        <RecentBlogs />
        <ProjectsSection />
        <Footer />
    </div>
</Layout>

<style>
    #site-wrap {
        padding: 0 24px;
        max-width: calc(var(--max-w) + 48px);
        margin: 0 auto;
    }

    #site-wrap > :global(*) {
        padding-left: 0;
        padding-right: 0;
    }
</style>
