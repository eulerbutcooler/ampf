---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import NavBar from "../../components/NavBar.astro";
import Callout from "../../components/mdx/Callout.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
    const posts = await getCollection(
        "blog",
        ({ data }) => data.draft !== true,
    );
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Format "2025-04-12" → "April 12, 2025"
const fmt = new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
});
const dateLabel = fmt.format(new Date(post.data.date));
---

<Layout
    title={`${post.data.title} — eulerbutcooler`}
    description={post.data.description}
    ogImage={new URL(`/open-graph/${post.id}.png`, Astro.site).toString()}
>
    <div id="site-wrap">
        <NavBar />

        <article id="post">
            <!-- Header -->
            <header id="post-header">
                <div id="post-meta-top">
                    <span class="post-tag">[{post.data.tag}]</span>
                    <span class="post-date">{dateLabel}</span>
                </div>
                <h1 id="post-title">{post.data.title}</h1>
                <p id="post-desc">{post.data.description}</p>
                <div id="post-divider"></div>
            </header>

            <div id="post-body">
                <Content components={{ Callout }} />
            </div>

            <!-- Back link -->
            <footer id="post-footer">
                <a href="/blogs" id="back-link">← All posts</a>
            </footer>
        </article>

        <Footer />
    </div>
</Layout>

<style>
    #site-wrap {
        padding: 0 24px;
        max-width: calc(var(--max-w) + 48px);
        margin: 0 auto;
    }

    /* Header */
    #post {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 48px 0 60px;
    }

    #post-header {
        margin-bottom: 40px;
        padding-bottom: 32px;
        border-bottom: 1px solid var(--border);
    }

    #post-meta-top {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 16px;
    }

    .post-tag {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--blue-dim);
    }

    .post-date {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--blue-dim);
    }

    #post-title {
        font-family: var(--font-doto);
        font-variation-settings: "ROND" 0;
        font-size: clamp(1.8rem, 5vw, 3rem);
        font-weight: 700;
        letter-spacing: 0.04em;
        line-height: 1.1;
        text-transform: uppercase;
        color: var(--accent-orange);
        margin-bottom: 16px;
    }

    #post-desc {
        font-family: var(--font-sans);
        font-size: 14px;
        line-height: 1.75;
        letter-spacing: 0.02em;
        color: var(--blue-mid);
        max-width: 560px;
    }

    /* Body prose */
    #post-body {
        font-family: var(--font-sans);
        font-size: 15px;
        line-height: 1.85;
        letter-spacing: 0.01em;
        color: var(--blue);
        max-width: 680px;
    }

    #post-body :global(h2) {
        font-family: var(--font-doto);
        font-variation-settings: "ROND" 0;
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--accent-orange);
        margin: 2.4em 0 0.8em;
        padding-bottom: 8px;
        border-bottom: 1px solid var(--border);
    }

    #post-body :global(h3) {
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent-teal);
        margin: 2em 0 0.6em;
    }

    #post-body :global(p) {
        margin-bottom: 1.4em;
        font-size: 16px;
        line-height: 1.6;
        color: var(--blue-mid);
    }

    #post-body :global(a) {
        color: var(--accent-teal);
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    #post-body :global(code) {
        font-family: var(--font-mono);
        font-size: 0.88em;
        background: var(--blue-subtle);
        padding: 1px 5px;
        border-radius: 2px;
        color: var(--blue);
    }

    #post-body :global(pre) {
        background: var(--blue-subtle);
        border: 1px solid var(--border);
        padding: 18px 20px;
        overflow-x: auto;
        margin: 1.6em 0;
        border-radius: 2px;
    }

    #post-body :global(pre code) {
        background: none;
        padding: 0;
        font-size: 14px;
        line-height: 1.7;
        color: #e4e4e7;
    }

    #post-body :global(ul),
    #post-body :global(ol) {
        padding-left: 1.4em;
        margin-bottom: 1.4em;
        color: var(--blue-mid);
    }

    #post-body :global(li) {
        margin-bottom: 0.4em;
    }

    #post-body :global(blockquote) {
        border-left: 2px solid var(--accent-orange);
        padding-left: 16px;
        margin: 1.6em 0;
        color: var(--blue-dim);
        font-style: normal;
    }

    #post-body :global(hr) {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2.4em 0;
    }

    /* Footer */
    #post-footer {
        margin-top: 56px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
    }

    #back-link {
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--blue-dim);
        text-decoration: none;
        transition: color 0.15s;
    }

    #back-link:hover {
        color: var(--blue);
    }

    @media (max-width: 640px) {
        #post {
            padding: 32px 0 48px;
        }
        #post-title {
            font-size: clamp(1.5rem, 8vw, 2.4rem);
        }
    }
</style>
